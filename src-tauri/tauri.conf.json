{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AHKforge",
  "identifier": "io.github.insmnaxd.ahkforge",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AHKforge",
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self'",
        "font-src": "'self'",
        "object-src": "'none'",
        "form-action": "'none'",
        "frame-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Aleksander Łysoń",
    "copyright": "Copyright © 2026 Aleksander Łysoń",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "homepage": "https://github.com/insmnaxd/AHKforge",
    "shortDescription": "AutoHotkey v1 and v2 script generator",
    "longDescription": "A local desktop generator for AutoHotkey v1 and v2 hotkeys, hotstrings, and remaps.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
